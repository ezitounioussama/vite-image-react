{
  "name": "vite-image-react",
  "version": "1.0.0-alpha.3",
  "description": "Content-aware, device-adaptive image optimizer for React + Vite. Auto-converts to AVIF/WebP/JPEG with SSIM auto-tune, face detection, SVGO, and device-tier delivery. Built by @ezitounioussama at gotodev.ma.",
  "keywords": [
    "image",
    "optimizer",
    "optimization",
    "compression",
    "vite",
    "vite-plugin",
    "react",
    "react-component",
    "image-optimization",
    "image-compression",
    "webp",
    "avif",
    "jpeg",
    "png",
    "svg",
    "svgo",
    "sharp",
    "responsive-images",
    "lazy-loading",
    "blur-up",
    "placeholder",
    "ssim",
    "content-aware",
    "perceptual",
    "saliency",
    "face-detection",
    "device-adaptive",
    "performance",
    "core-web-vitals",
    "lcp",
    "cls",
    "image-loader",
    "picture",
    "srcset"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin.d.ts",
      "default": "./dist/vite-plugin.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!playground"
  ],
  "scripts": {
    "build": "tsup --clean",
    "preview": "vite preview playground",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "size-limit",
    "prepare": "echo 'ready'"
  },
  "author": "Oussama Ezitouni <ezitounioussama@gmail.com> (https://gotodev.ma)",
  "sideEffects": false,
  "$schema": "https://raw.githubusercontent.com/vitejs/vite-plugin-registry/refs/heads/main/data/schema/extended-package-json.schema.json",
  "compatiblePackages": {
    "schemaVersion": 1,
    "vite": {
      "type": "compatible",
      "versions": "^7.0.0 || ^8.0.0"
    }
  },
  "license": "MIT",
  "homepage": "https://github.com/ezitounioussama/vite-image-react#readme",
  "bugs": {
    "url": "https://github.com/ezitounioussama/vite-image-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ezitounioussama/vite-image-react.git"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "sharp": "^0.34.5",
    "svgo": "^3.3.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "vite": "^7.0.0"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "5 KB"
    },
    {
      "path": "dist/vite-plugin.js",
      "limit": "12 KB"
    }
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@size-limit/file": "^12.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.2",
    "happy-dom": "^20.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
